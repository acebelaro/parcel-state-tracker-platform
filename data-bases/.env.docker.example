# Docker Deployment Environment Configuration for MongoDB
# Parcel State Tracker Platform
#
# Copy this file to .env.docker and configure for your Docker deployment

# MongoDB Configuration
MONGODB_USERNAME=admin
MONGODB_PASSWORD=admin123
MONGODB_DB_NAME=parcel_tracker
MONGODB_PORT=27017

# MongoDB Express Configuration (Web UI for MongoDB)
# Access at http://localhost:8081
MONGO_EXPRESS_PORT=8081
MONGO_EXPRESS_AUTH=true
MONGO_EXPRESS_USERNAME=admin
MONGO_EXPRESS_PASSWORD=express123