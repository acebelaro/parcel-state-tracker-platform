# Python Ingest Service Environment Configuration
# Parcel State Tracker Platform
#
# Copy this file to .env and configure for your environment

# MongoDB Configuration
# For authentication, provide username and password
# If not provided, connection will be unauthenticated
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_USERNAME=
MONGODB_PASSWORD=
MONGODB_DB_NAME=parcel_tracker
MONGODB_AUTH_SOURCE=admin

# Flask Configuration
FLASK_ENV=development
FLASK_PORT=5000

# Maximum tracking entries per parcel (-1 for unlimited/no purge)
MAX_TRACKING_ENTRIES=10
