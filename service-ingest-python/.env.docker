# Docker Deployment Environment Configuration
# Parcel State Tracker Platform
#
# Copy this file to .env.docker and configure for your Docker deployment
# MongoDB is now included in this docker-compose for proper networking
#
# MongoDB Configuration
MONGODB_HOST=mongodb
MONGODB_PORT=27017
MONGODB_USERNAME=admin
MONGODB_PASSWORD=admin123
MONGODB_DB_NAME=parcel_tracker

# Flask Configuration
FLASK_ENV=production
FLASK_PORT=5000
