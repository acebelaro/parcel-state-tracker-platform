# Docker Deployment Environment Configuration
# Parcel State Tracker Platform
#
# Copy this file to .env.docker and configure for your Docker deployment
# Note: MongoDB is deployed separately via the data-bases docker-compose

# MongoDB Configuration
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_USERNAME=admin
MONGODB_PASSWORD=admin123
MONGODB_DB_NAME=parcel_tracker

# Flask Configuration
FLASK_ENV=production
FLASK_PORT=5000

# Maximum tracking entries per parcel (-1 for unlimited/no purge)
MAX_TRACKING_ENTRIES=10
